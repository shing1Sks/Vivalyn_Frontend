# SUPABASE SETUP
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# BACKEND API
VITE_BACKEND_URL=http://localhost:8000

# ── PAYMENTS ─────────────────────────────────────────────────────────────────
# See PAYMENTS_SETUP.md for step-by-step instructions on getting these values.

# Razorpay publishable key (safe to expose — same value as RAZORPAY_KEY_ID in backend)
# Use rzp_test_* for test mode, rzp_live_* for production
VITE_RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID

# Stripe publishable key (safe to expose)
# Use pk_test_* for test mode, pk_live_* for production
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY
